# MQTT broker configuration.
#
# LOCAL DEV: copy to `.env.local` and run `npm run proxy` + `npm run dev`.
# CLOUD:    copy `.env.production.example` → `.env.production`, or set env vars
#           in Vercel — see DEPLOY.md. No proxy needed.
#
# IMPORTANT: Vite embeds all VITE_* variables into the client bundle.

# --- Local (browser → proxy → Docker Mosquitto) ---
VITE_MQTT_BROKER_URL=ws://localhost:9001

# --- Cloud (browser → HiveMQ WSS directly) ---
# VITE_MQTT_BROKER_URL=wss://YOUR_CLUSTER.s1.eu.hivemq.cloud:8884/mqtt

# Topic pattern to subscribe to. `#` is the multi-level wildcard — in
# single-card mode we just want any message under `hackathon/` to populate
# the one card. Narrow when multi-device routing returns.
VITE_MQTT_TOPIC_PATTERN=hackathon/#

# Authentication. Leave blank for anonymous brokers.
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=

# Outbound topic for the global "alert sound" toggle in the settings modal.
# Published as JSON `{ "sound": true|false }` with retain:true.
VITE_MQTT_SOUND_TOPIC=sigita_liepe/the_force
