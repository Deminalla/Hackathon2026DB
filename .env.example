# MQTT broker configuration.
#
# PRODUCTION / DEMO (recommended): use hosted MQTT — copy `.env.production.example`
# to `.env.production` or set the same VITE_* vars in Vercel. Browser connects
# via WSS directly to HiveMQ. No proxy. See docs/MQTT.md.
#
# OPTIONAL LOCAL DEV (proxy + Docker Mosquitto): copy this file to `.env.local`,
# uncomment ws://localhost:9001 below, run `docker compose up -d`, `npm run proxy`,
# `npm run dev`. See docs/LOCAL_DEV.md.
#
# IMPORTANT: Vite embeds all VITE_* variables into the client bundle.

# --- Hosted MQTT (use for demo + Vercel) — see .env.production.example ---
# VITE_MQTT_BROKER_URL=wss://YOUR_CLUSTER.s1.eu.hivemq.cloud:8884/mqtt

# --- Optional local dev only (npm run proxy → Mosquitto :1883) ---
# VITE_MQTT_BROKER_URL=ws://localhost:9001

# Must match ESP publish topic (MQTT_TOPIC_PUBLISH in secrets.h)
VITE_MQTT_TOPIC_PATTERN=darkside

# Authentication. Leave blank for anonymous brokers.
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=

# Outbound topic for the global "alert sound" toggle in the settings modal.
# Published as JSON `{ "sound": true|false }` with retain:true.
VITE_MQTT_SOUND_TOPIC=sigita_liepe/the_force
