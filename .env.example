# MQTT broker configuration.
# Copy this file to `.env.local` (which is gitignored by `*.local`) and fill in real values.
#
# IMPORTANT: Vite embeds all VITE_* variables into the client bundle, so anything
# put here is readable by anyone who loads the page. This pattern is fine for a
# LAN-only hackathon broker; do NOT reuse it for production secrets.

# WebSocket URL of the MQTT broker. Browsers cannot use raw TCP / port 1883.
VITE_MQTT_BROKER_URL=ws://10.6.10.36:9001

# Topic pattern to subscribe to. `+` is the single-level wildcard.
VITE_MQTT_TOPIC_PATTERN=hackathon/sensors/+

# Authentication. Leave blank for anonymous brokers.
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=
