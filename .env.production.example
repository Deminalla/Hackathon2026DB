# Production build (Vercel / Netlify / `npm run build`).
# Copy to `.env.production` for local production builds, or set the same keys
# in your host's Environment Variables UI (recommended for deploy).
#
# HiveMQ Cloud → Cluster → Connection details:
#   WebSocket URL: wss://YOUR_CLUSTER.s1.eu.hivemq.cloud:8884/mqtt
#   Username / password: from the cluster access management screen

VITE_MQTT_BROKER_URL=wss://YOUR_CLUSTER.s1.eu.hivemq.cloud:8884/mqtt
VITE_MQTT_TOPIC_PATTERN=darkside
VITE_MQTT_USERNAME=your-hivemq-username
VITE_MQTT_PASSWORD=your-hivemq-password
VITE_MQTT_SOUND_TOPIC=sigita_liepe/the_force
